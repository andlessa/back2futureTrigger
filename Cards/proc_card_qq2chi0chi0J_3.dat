import model ../../models/DipoleDM3/DipoleDM3_minimalH_UFO
define p = g u c d s u~ c~ d~ s~
define j = g u c d s u~ c~ d~ s~
define l+ = e+ mu+
define l- = e- mu-
define vl = ve vm vt
define vl~ = ve~ vm~ vt~
define c1 = ~chi1 ~chi1bar
define c2 = ~chi2 ~chi2bar
define c0 = ~chi0 ~chi0bar
define q = u c d s u~ c~ d~ s~
generate q q > c1 c2 / h, (c1 > b b~ c0), (c2 > b b~ c0)
add process q q > c1 c2 j  / h,  (c1 > b b~ c0), (c2 > b b~ c0)
output ../../qq2chi0chi0J_3_minimalH_scan
